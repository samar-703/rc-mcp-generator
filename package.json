{
  "name": "rc-mcp-generator",
  "version": "1.0.0",
  "private": true,
  "description": "CLI and template for generating minimal Rocket.Chat MCP servers.",
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "dev": "pnpm --filter @rc-mcp-generator/generator dev",
    "dev:cli": "pnpm --filter @rc-mcp-generator/generator dev:cli",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.5.2",
    "eslint": "^9.35.0",
    "msw": "^2.11.2",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.0",
    "vitest": "^3.2.4"
  }
}
