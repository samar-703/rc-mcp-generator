{
  "openapi": "3.0.0",
  "info": {
    "title": "Rocket.Chat Chat API",
    "version": "1.0.0"
  },
  "paths": {
    "/chat.postMessage": {
      "post": {
        "operationId": "postMessage",
        "summary": "Send a message",
        "description": "Post a message into a channel or room",
        "tags": ["messaging"],
        "parameters": [
          {
            "name": "X-Auth-Token",
            "in": "header",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "X-User-Id",
            "in": "header",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["channel", "text"],
                "properties": {
                  "channel": { "type": "string" },
                  "text": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/chat.search": {
      "get": {
        "operationId": "searchMessages",
        "summary": "Search messages",
        "description": "Search workspace messages",
        "tags": ["messaging"],
        "parameters": [
          {
            "name": "roomId",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "searchText",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "messages": {
                      "type": "array",
                      "items": { "type": "object" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
