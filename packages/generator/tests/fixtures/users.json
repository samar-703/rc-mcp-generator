{
  "openapi": "3.0.0",
  "info": {
    "title": "Rocket.Chat Users API",
    "version": "1.0.0"
  },
  "paths": {
    "/users.info": {
      "get": {
        "operationId": "getUserInfo",
        "summary": "Get user info",
        "description": "Fetch a Rocket.Chat user",
        "tags": ["users"],
        "parameters": [
          {
            "name": "username",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": {
                      "type": "object",
                      "properties": {
                        "_id": { "type": "string" },
                        "username": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
